{
  "exchange": {
    "providers": {
      "binance": {
        "environments": {
          "demo": {
            "accounts": {
              "main": {
                "credentials": {
                  "reference": "binance_demo_main",
                  "api_key": "${BINANCE_DEMO_API_KEY:${EXCHANGE_API_KEY}}",
                  "api_secret": "${BINANCE_DEMO_API_SECRET:${EXCHANGE_API_SECRET}}"
                },
                "markets": {
