{
  "bot": {
    "instance_id": "trading-bot-demo-main-usdm-futures",
    "target_id": "binance_demo_main_usdm_futures"
  },
  "trading": {
    "journal": {
      "enabled": true,
      "recovery": {
        "enabled": true
      }
    },
    "projection": {
      "snapshot_store": {
        "enabled": true
      }
    },
    "messaging": {
      "enabled": true,
      "topics": {
        "auto_create": true
      },
      "consumers": {
        "enabled": true,
        "auto_start": true
      }
    },
    "audit": {
      "pause_governance": {
        "file_store": {
          "enabled": true
        }
      }
    },
    "strategy": {
      "lfa": {
        "signal_runner": {
          "initial_delay_millis": 10000,
          "provider": "binance",
          "environment": "demo",
          "account": "main",
          "market": "usdm_futures",
          "lifecycle_state": "PAUSED",
          "min_warmup_market_data_symbols": 3,
          "min_warmup_top_of_book_symbols": 3,
          "max_candidate_market_data_symbols": 13,
          "target_quantity": "0.001",
          "target_notional_margin_balance_fraction": "0.01",
          "max_allocated_target_notional": "50",
          "max_strategy_run_notional": "50",
          "allocation_weighting_mode": "MARKET_QUALITY",
          "max_account_open_positions": 3,
          "max_symbol_open_positions": 1
        }
      }
    },
    "execution": {
      "pipeline": {
        "enabled": true
      },
      "risk_gate": {
        "order_limit": {
          "max_open_orders": 5,
          "target_limits": [
            {
              "provider": "binance",
              "environment": "demo",
              "account": "main",
              "market": "usdm_futures",
              "symbol": "BTCUSDT",
              "max_open_orders": 3
            },
            {
              "provider": "binance",
              "environment": "demo",
              "account": "main",
              "market": "usdm_futures",
              "symbol": "ETHUSDT",
              "max_open_orders": 3
            }
          ]
        }
      },
      "signal_planner": {
        "enabled": true,
        "defaults": {
          "provider": "binance",
          "environment": "demo",
          "account": "main",
          "market": "usdm_futures",
          "symbol": "BTCUSDT",
          "client_order_id_prefix": "tb-demo"
        },
        "instrument_universe": {
          "enabled": true,
          "refresh_exchange_metadata_before_planning": true,
          "require_exchange_metadata": true,
          "allowed_quote_assets": [
            "USDT"
          ],
          "allowed_contract_types": [
            "PERPETUAL"
          ],
          "require_market_data": true,
          "require_top_of_book": true,
          "max_market_data_age_millis": 30000,
          "max_spread_bps": "5",
          "min_top_of_book_quote_notional": "250",
          "min_daily_quote_volume": "100000000"
        }
      }
    },
    "intervention": {
      "remediation_orchestrator": {
        "enabled": true
      },
      "automated_policy": {
        "external_order_action": "CLOSE",
        "open_position_action": "CLOSE"
      },
      "automated_decision_service": {
        "enabled": true
      },
      "automated_remediation_runner": {
        "enabled": true,
        "initial_delay_millis": 5000,
        "target": {
          "provider": "binance",
          "environment": "demo",
          "account": "main",
          "market": "usdm_futures"
        }
      },
      "remediation_executor_policy": {
        "enabled": true,
        "exchange_execution_enabled": true,
        "report_only": false,
        "allowed_operations": [
          "CANCEL_ORDER",
          "CLOSE_POSITION",
          "REDUCE_POSITION",
          "AMEND_ORDER"
        ],
        "position_order_policy": {
          "one_way_reduce_only_enabled": true,
          "allowed_symbols": [
            "BTCUSDT",
            "ETHUSDT"
          ],
          "max_position_quantity": "0.001",
          "chunk_close_when_max_quantity_exceeded": true,
          "max_position_notional": "250",
          "required_margin_type": "cross",
          "min_leverage": "1",
          "max_leverage": "5"
        },
        "managed_order_amendment_policy": {
          "enabled": true,
          "allowed_symbols": [
            "BTCUSDT",
            "ETHUSDT"
          ],
          "max_quantity_decrease_fraction": "0.50",
          "max_price_drift_fraction": "0.02",
          "max_projection_age_millis": 30000
        },
        "adopted_order_lifecycle_policy": {
          "enabled": true,
          "allow_cancel": true,
          "allow_amend": true,
          "allowed_symbols": [
            "BTCUSDT",
            "ETHUSDT"
          ],
          "max_projection_age_millis": 30000
        }
      }
    }
  },
  "exchange": {
    "providers": {
      "binance": {
        "environments": {
          "demo": {
            "accounts": {
              "main": {
                "markets": {
                  "usdm_futures": {
                    "user_data": {
                      "runtime_enabled": true
                    },
                    "market_data": {
                      "runtime_enabled": true
                    },
                    "reconciliation": {
                      "runtime_enabled": true,
                      "interval_seconds": 30,
                      "open_orders_enabled": true,
                      "futures_balances_enabled": true,
                      "futures_account_enabled": true,
                      "futures_positions_enabled": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
