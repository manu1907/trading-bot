                    }
                  },
                  "usdm_futures": {
                    "rest": {
                      "base_url": "https://demo-fapi.binance.com"
                    },
                    "websocket": {
                      "base_url": "wss://fstream.binancefuture.com"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
