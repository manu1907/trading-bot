  "exchange": {
    "providers": {
      "binance": {
        "environments": {
          "demo": {
            "accounts": {
              "main": {
                "markets": {
                  "usdm_futures": {
                    "user_data": {
                      "runtime_enabled": true
                    },
                    "market_data": {
                      "runtime_enabled": true,
                      "streams": [
                        "btcusdt@bookTicker",
                        "btcusdt@aggTrade",
                        "ethusdt@bookTicker",
                        "ethusdt@aggTrade"
                      ]
                    },
                    "reconciliation": {
                      "runtime_enabled": true,
                      "interval_seconds": 30,
                      "open_orders_enabled": true,
                      "open_order_symbols": [
                        "BTCUSDT",
                        "ETHUSDT"
                      ],
                      "futures_balances_enabled": true,
                      "futures_account_enabled": true,
                      "futures_positions_enabled": true
                    }
                  }
                }
              }
            }
          }
        }
      }
