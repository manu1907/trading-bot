<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Spring owns these injected singleton services; they are not representation exposure. -->
    <Match>
        <Class name="io.github.manu.config.ConfigBootstrap"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="io.github.manu.config.service.ConfigReloadService"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="io.github.manu.exchange.runtime.ExchangeManager"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Avro SpecificRecord classes are generated code; their mutable builders and cached decoders are framework internals. -->
    <Match>
        <Class name="~io\.github\.manu\.events\.v1\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,MS_EXPOSE_REP"/>
    </Match>
</FindBugsFilter>
